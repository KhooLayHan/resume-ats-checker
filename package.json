{
  "name": "resuming",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.4.2",
      "zod": "^4.4.3",
      "typescript": "^6",
      "@types/node": "^22.13.14"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "check-types": "turbo run check-types",
    "dev:web": "turbo run dev -F web",
    "check": "ultracite check",
    "fix": "ultracite fix"
  },
  "dependencies": {
    "@resuming/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@resuming/config": "workspace:*",
    "@types/node": "catalog:",
    "lefthook": "latest",
    "oxfmt": "latest",
    "oxlint": "latest",
    "turbo": "^2.10.2",
    "typescript": "catalog:",
    "ultracite": "7.9.3"
  },
  "packageManager": "bun@1.3.9"
}
